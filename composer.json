{
  "name": "agarraud/agarraud-monorepo-first-package",
  "require": {
    "symfony/http-kernel": "^5.0",
    "agarraud/agarraud-monorepo-second-package": "1.0.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
