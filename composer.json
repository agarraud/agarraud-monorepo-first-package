{
    "name": "agarraud/agarraud-monorepo-first-package",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "symfony/http-kernel": "^5.0",
        "agarraud/agarraud-monorepo-second-package": "^1.0.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Agarraud\\AgarraudMonorepoFirstPackage\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agarraud\\AgarraudMonorepoFirstPackage\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.1-dev"
        }
    }
}
